# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CricAPI (get from cricapi.com — free tier gives 100 req/day)
CRICAPI_KEY=your_cricapi_key

# IPL 2025 Series ID (get this from CricAPI /series endpoint after signing up)
# Search for "Indian Premier League 2025" to find the series ID
IPL_SERIES_ID=your_ipl_2025_series_id

# Invite system — set this to whatever secret code you want your friends to use
INVITE_CODE=your_secret_invite_code

# Vercel Cron secret (set any random string, use same in vercel.json if protecting cron)
CRON_SECRET=your_cron_secret

# App URL (used for OAuth callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_CRON_SECRET=same_value_as_your_CRON_SECRET
NEXT_PUBLIC_ADMIN_EMAIL=your_actual_gmail_address